# ── Rust / Cargo (workspace root — `cargo` from any member uses this) ───────
/target/
**/*.rs.bk
*.pdb

# ── Firmware / embedded ──────────────────────────────────────────────────────
*.uf2
*.hex
*.bin
*.elf
*.map
*.lst
*.o
build/
.build/
.pio/
.pioenvs/
.piolibdeps/

# ── JS / Node / pnpm ─────────────────────────────────────────────────────────
node_modules/
dist/
dist-ssr/
*.local
.turbo/
.cache/
*.tsbuildinfo
.eslintcache
coverage/
.nyc_output/

# ── Environment & secrets (never commit) ──────────────────────────────────────
.env
.env.*
!.env.example

# ── IDE (keep optional team files — un-ignore below) ─────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Logs ─────────────────────────────────────────────────────────────────────
*.tmp
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Sandbox (local-only experiments — use research/ for tracked work) ─────────
sandbox/

# ── SDKs (clone separately — see sdks/README.md) ────────────────────────────
sdks/*
!sdks/README.md

# ── CAD (KiCad) ───────────────────────────────────────────────────────────────
*-cache.lib
*-backups/
*.kicad_prl
fp-info-cache
